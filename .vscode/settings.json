{
  // C/C++: clangd is the language server (compile database from CMake's windows
  // slice, see .clangd). Keep the Microsoft C/C++ engine off so the two do not fight.
  "clangd.arguments": ["--background-index", "--clang-tidy", "--header-insertion=never"],
  "C_Cpp.intelliSenseEngine": "disabled",

  // CMake Tools: the Makefile owns configure; the Windows core builds under windows/build.
  "cmake.configureOnOpen": false,
  "cmake.buildDirectory": "${workspaceFolder}/windows/build",

  // Swift: load each package under the workspace and use the pinned Xcode toolchain.
  "swift.searchSubfoldersForPackages": true,
  "swift.swiftEnvironmentVariables": {
    "DEVELOPER_DIR": "/Applications/Xcode.app/Contents/Developer"
  },

  // Format on save, each language by its own configured tool.
  "editor.formatOnSave": true,
  "[c]": { "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd" },
  "[cpp]": { "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd" },
  "[json]": { "editor.defaultFormatter": "biomejs.biome" },
  "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },
  "[javascript]": { "editor.defaultFormatter": "biomejs.biome" },
  "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
  "[dart]": { "editor.defaultFormatter": "Dart-Code.dart-code" },

  // Generated and build trees stay out of the explorer, search, and file watcher.
  "files.exclude": {
    "**/.build": true,
    "**/build": true,
    "**/DerivedData": true,
    "**/.turbo": true,
    "**/.gradle": true,
    "**/.dart_tool": true
  },
  "search.exclude": {
    "**/.build": true,
    "**/build": true,
    "**/_deps": true,
    "**/node_modules": true,
    "**/.gradle": true
  }
}
