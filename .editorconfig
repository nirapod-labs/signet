root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Swift and Kotlin follow their own 4-space community conventions; C++, Dart,
# JSON, and YAML use the 2-space default above.
[*.{swift,kt,kts}]
indent_size = 4

[Makefile]
indent_style = tab
